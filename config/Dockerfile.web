ARG PYTHON_IMAGE=python:3.14-slim
FROM ${PYTHON_IMAGE}

ARG APP_UID=10001
ARG APP_GID=10001

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/src \
    HOME=/tmp/modacct-home

RUN groupadd --gid ${APP_GID} modacct \
    && useradd --uid ${APP_UID} --gid ${APP_GID} --no-create-home --shell /usr/sbin/nologin modacct

WORKDIR /app

COPY requirements.txt ./
RUN python -m pip install --no-cache-dir --upgrade pip \
    && python -m pip install --no-cache-dir -r requirements.txt

COPY --chown=${APP_UID}:${APP_GID} . .
RUN install -d -o ${APP_UID} -g ${APP_GID} /tmp/modacct-home

USER ${APP_UID}:${APP_GID}

EXPOSE 8501

CMD ["streamlit", "run", "src/apps/web/app.py", "--server.port=8501", "--server.address=0.0.0.0", "--server.headless=true"]
