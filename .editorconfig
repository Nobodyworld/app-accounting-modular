# Standard .editorconfig for Organization Repos
# Global settings that work across most stacks
# Repo-specific overrides can be added below

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,ts,jsx,tsx,json,css,scss,html,md,yaml,yml}]
indent_style = space
indent_size = 2

[*.{py,pyi}]
indent_style = space
indent_size = 4

[*.{rs,toml}]
indent_style = space
indent_size = 4

[*.{go,mod,sum}]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
