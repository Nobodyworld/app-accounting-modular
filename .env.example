# Modular Accounting environment configuration
# Copy this file to `.env` and adjust the values for your deployment.

# --- Core Application ---
MODACCT_DATABASE_URL=postgresql://user:password@localhost:5432/modacct
MODACCT_LOG_LEVEL=INFO
MODACCT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Security ---
# Provide a stable, high-entropy secret for signing JWTs.
MODACCT_JWT_SECRET_KEY=replace-with-32+character-secret
# Optional: override signing algorithm (HS256, RS256, ES256, etc.).
MODACCT_JWT_ALGORITHM=HS256

# --- Third-party integrations ---
MODACCT_OPENEX_APP_ID=
MODACCT_ALPHAVANTAGE_KEY=
MODACCT_NEWSAPI_KEY=
MODACCT_GDELT_USER_AGENT=

# --- Optional ---
# Path to a dotenv file to load before constructing settings.
MODACCT_ENV_FILE=
